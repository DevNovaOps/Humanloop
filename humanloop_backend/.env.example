# ============================================================
# HumanLoop Backend — Environment Variables
# Copy this file as .env and fill in your actual values
# ============================================================

# ── Django Core ──────────────────────────────────────────────
SECRET_KEY=django-insecure-CHANGE-THIS-IN-PRODUCTION
DEBUG=True
ALLOWED_HOSTS=*

# ── Database (Local MySQL) ──────────────────────────────────
# Used when NOT running on Railway
DB_NAME=humanloop
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_PORT=3306

# ── Database (Railway MySQL — auto-injected by Railway) ─────
# These are set automatically when you add a MySQL plugin on Railway:
# MYSQLDATABASE, MYSQLUSER, MYSQLPASSWORD, MYSQLHOST, MYSQLPORT
# RAILWAY_ENVIRONMENT (auto-set by Railway, used to detect deployment)

# ── Email (Gmail SMTP) ──────────────────────────────────────
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=your_email@gmail.com

# ── Razorpay Payment Gateway ────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXX
PLATFORM_COMMISSION_PERCENT=5

# ── Stripe Payment Gateway ──────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXX
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXX

# ── AI Model (Ollama — local only) ──────────────────────────
AI_MODEL=qwen2:0.5b

# ── Railway-specific (set in Railway dashboard) ─────────────
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app
# CUSTOM_DOMAIN=yourdomain.com
