{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": [
        "python"
      ],
      "phases": {
        "setup": {
          "nixPkgs": [
            "python313",
            "gcc",
            "pkg-config"
          ]
        },
        "install": {
          "cmds": [
            "pip install -r requirements.txt"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "python manage.py migrate --no-input && python manage.py collectstatic --no-input && gunicorn humanloop_backend.wsgi --bind 0.0.0.0:$PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}